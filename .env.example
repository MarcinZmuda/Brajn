# === Authentication ===
API_KEY=your-api-key-here
PANEL_LOGIN=admin
PANEL_PASSWORD=your-panel-password

# === S1: SERP Analysis ===
SERPAPI_KEY=your-serpapi-key

# === Cloudflare Browser Rendering (default scraper) ===
# If not set, falls back to requests+trafilatura
CF_BROWSER_RENDERING_URL=https://your-worker.your-subdomain.workers.dev
CF_BROWSER_RENDERING_TOKEN=your-cf-token

# === AI/LLM ===
ANTHROPIC_API_KEY=your-anthropic-key
# Optional: OpenAI for dual-engine
OPENAI_API_KEY=your-openai-key

# === Firebase ===
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# OR inline JSON:
# FIREBASE_CREDS_JSON={"type":"service_account",...}

# === Optional ===
GEMINI_API_KEY=your-gemini-key
DEBUG_MODE=false
ENTITY_SEO_ENABLED=true
